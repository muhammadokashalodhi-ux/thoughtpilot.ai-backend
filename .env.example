# ================================================================
# SupplAI Backend — Environment Variables
# Copy this to .env and fill in all values
# ================================================================

# ── DATABASE (Railway PostgreSQL) ──
DATABASE_URL=postgresql://postgres:password@localhost:5432/supplai

# ── JWT AUTH ──
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_random_secret_here
JWT_EXPIRES_IN=7d

# ── ADMIN ──
# Password to access /admin routes
ADMIN_PASSWORD=your_strong_admin_password_here
ADMIN_JWT_SECRET=your_admin_jwt_secret_here

# ── GROQ AI ──
GROQ_API_KEY=gsk_your_key_here

# ── NOTIFICATIONS ──
# WhatsApp via CallMeBot
WA_APIKEY=your_callmebot_apikey

# Email via Gmail App Password
EMAIL_FROM=yourname@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── APP ──
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── RAILWAY (set after deploy) ──
RAILWAY_STATIC_URL=https://your-app.railway.app
